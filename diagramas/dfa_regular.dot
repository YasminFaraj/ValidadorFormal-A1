// DFA — CPF formato ddd.ddd.ddd-dd
// Alfabeto: {0-9, '.', '-'}
// Estados: q0..q13, ERRO
// Estado inicial: q0
// Estado final: q13

digraph DFA_CPF {
    rankdir=LR;
    node [shape=circle fontname="monospace" fontsize=11];
    edge [fontname="monospace" fontsize=10];

    // Estado inicial
    inicio [shape=none label=""];
    inicio -> q0;

    // Estado de aceitação
    q13 [shape=doublecircle];

    // Estado de erro
    ERRO [style=filled fillcolor=lightcoral];

    // Dígitos (0-9)
    q0  -> q1  [label="0-9"];
    q1  -> q2  [label="0-9"];
    q2  -> q3  [label="0-9"];
    q3  -> q4  [label="\".\""];
    q4  -> q5  [label="0-9"];
    q5  -> q6  [label="0-9"];
    q6  -> q7  [label="0-9"];
    q7  -> q8  [label="\".\""];
    q8  -> q9  [label="0-9"];
    q9  -> q10 [label="0-9"];
    q10 -> q11 [label="0-9"];
    q11 -> q12 [label="\"-\""];
    q12 -> q13 [label="0-9"];
    q13 -> ERRO [label="0-9"];

    // Transições de erro (símbolo errado em qualquer estado)
    // (omitidas para clareza; qualquer símbolo não listado vai para ERRO)
}
